<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- 共享视觉样式：毛玻璃壳 + 实色容器设计语言（对应 settings-glass-ui-demo.html） -->

  <!-- ===== 排版 ===== -->
  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.Small">
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="TextBlock.Muted">
    <Setter Property="Foreground" Value="{DynamicResource AppMutedForegroundBrush}" />
  </Style>
  <Style Selector="TextBlock.NavIcon">
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ===== 容器 ===== -->
  <Style Selector="Border.Card">
    <Setter Property="Background" Value="{DynamicResource AppCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AppCardCornerRadius}" />
    <Setter Property="Padding" Value="16" />
  </Style>
  <Style Selector="Border.Separator">
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <!-- ===== 设置行：左侧文案 + 右侧控件 ===== -->
  <Style Selector="Grid.SettingRow">
    <Setter Property="Margin" Value="0,10" />
  </Style>
  <Style Selector="Grid.SettingRow > StackPanel.Copy">
    <Setter Property="Spacing" Value="2" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,16,0" />
  </Style>

  <!-- ===== 按钮 ===== -->
  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12,7" />
  </Style>
  <Style Selector="Button.Ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button.Ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
  </Style>
  <Style Selector="Button.Ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppNavSelectedBrush}" />
  </Style>
  <Style Selector="Button.Primary">
    <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryForegroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight1}" />
    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryForegroundBrush}" />
  </Style>
  <Style Selector="Button.Primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryForegroundBrush}" />
  </Style>

  <!-- 窗口控制按钮 -->
  <Style Selector="Button.WindowButton">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="2,0,0,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.WindowButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
  </Style>
  <Style Selector="Button.WindowClose:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#C42B1C" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- Avalonia 类型选择器不匹配派生类型，ToggleButton 需单独声明同样的外观 -->
  <Style Selector="ToggleButton.WindowButton">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="2,0,0,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.WindowButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
  </Style>
  <Style Selector="ToggleButton.WindowButton:checked /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppNavSelectedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryBrush}" />
  </Style>

  <!-- ===== 侧栏导航项（RadioButton 承载互斥选中态） ===== -->
  <Style Selector="RadioButton.Nav">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="RootBorder"
                Background="Transparent"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Grid>
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center" />
            <Border Name="Indicator"
                    Width="3" Height="16"
                    CornerRadius="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppPrimaryBrush}"
                    Opacity="0">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.Nav /template/ Border#RootBorder">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="RadioButton.Nav:pointerover /template/ Border#RootBorder">
    <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
  </Style>
  <Style Selector="RadioButton.Nav:checked /template/ Border#RootBorder">
    <Setter Property="Background" Value="{DynamicResource AppNavSelectedBrush}" />
  </Style>
  <Style Selector="RadioButton.Nav:checked /template/ Border#Indicator">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- ===== 表单控件基础 ===== -->
  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="MinHeight" Value="34" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="MinHeight" Value="34" />
  </Style>
  <Style Selector="NumericUpDown">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="MinHeight" Value="34" />
  </Style>
  <Style Selector="ToggleSwitch">
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <!-- ===== 进度条 ===== -->
  <Style Selector="ProgressBar">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="6" />
    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryBrush}" />
  </Style>
</Styles>
