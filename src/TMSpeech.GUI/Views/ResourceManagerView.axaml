<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TMSpeech.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TMSpeech.GUI.Views.ResourceManagerView">
  <Design.DataContext>
    <vm:ResourceManagerViewModel />
  </Design.DataContext>
  <DockPanel>
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,12,*" Margin="0,0,0,12">
      <Button Grid.Column="0" Command="{Binding LoadCommand}">刷新</Button>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <ProgressBar IsVisible="{Binding Loading}" IsIndeterminate="True" Width="140" />
        <TextBlock Text="{Binding LoadMessage}"
                   Foreground="{DynamicResource AppDestructiveBrush}"
                   VerticalAlignment="Center" TextWrapping="Wrap" />
      </StackPanel>
    </Grid>
    <TextBlock DockPanel.Dock="Bottom" Classes="Small Muted" Margin="0,10,0,16" TextWrapping="Wrap"
               Text="请在 https://github.com/jxlpzqc/TMSpeechCommunity 贡献模型和插件。" />
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Items, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Classes="Card" Margin="0,0,0,10" Padding="16,14">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="3" Margin="0,0,16,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding ResouceInfo.Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ResouceInfo.Desc}" Classes="Small Muted" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                  <Border IsVisible="{Binding IsInstalled}" CornerRadius="999"
                          Background="{DynamicResource AppAccentBrush}"
                          Padding="10,4" VerticalAlignment="Center">
                    <TextBlock Text="已安装" Classes="Small"
                               Foreground="{DynamicResource AppPrimaryBrush}" />
                  </Border>
                  <Button Classes="Primary" IsVisible="{Binding IsInstallButtonShown}"
                          Command="{Binding InstallCommand}"
                          Content="{Binding InstallButtonText}" />
                  <Button IsVisible="{Binding IsPauseButtonShown}" Command="{Binding PauseCommand}">暂停</Button>
                  <Button IsVisible="{Binding IsUninstallButtonShown}" Command="{Binding UninstallCommand}">移除</Button>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            IsVisible="{Binding IsProgressShown}" Margin="0,12,0,0" Spacing="6">
                  <ProgressBar Maximum="100"
                               Value="{Binding Progress}"
                               IsIndeterminate="{Binding IsIndeterminate}" />
                  <Grid IsVisible="{Binding !IsIndeterminate}">
                    <TextBlock Text="{Binding Speed}" Classes="Small Muted" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding Progress, StringFormat={}{0}%}" Classes="Small Muted"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <TextBlock IsVisible="{Binding IsFailed}"
                             Foreground="{DynamicResource AppDestructiveBrush}"
                             Classes="Small" TextWrapping="Wrap"
                             Text="{Binding FailReason}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
