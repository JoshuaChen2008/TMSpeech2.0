<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TMSpeech.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:TMSpeech.GUI.Views"
        xmlns:aconverter="clr-namespace:Avalonia.Markup.Xaml.Converters;assembly=Avalonia.Markup.Xaml"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TMSpeech.GUI.Views.MainWindow"
        Icon="/Assets/tmspeech.ico"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Topmost="True"
        Background="Transparent"
        Title="TMSpeech"
        CanResize="True"
        Height="180"
        Width="800"
        IsHitTestVisible="{Binding !IsLocked}"
        PointerPressed="Window_PointerPressed"
        PointerMoved="Window_PointerMoved">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/IconResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <aconverter:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </ResourceDictionary>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Grid#mainGrid">
      <Setter Property="Background" Value="{Binding CaptionStyle.BackgroundColor, Converter={StaticResource ColorToBrushConverter}}" />
    </Style>
    <Style Selector="Grid#mainGrid:pointerover">
      <Setter Property="Background"
              Value="{Binding CaptionStyle.MouseHover, Converter={StaticResource ColorToBrushConverter}}" />
    </Style>
    <Style Selector="Grid#mainGrid Border#controls">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Grid#mainGrid:pointerover Border#controls">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>
  <Grid Name="mainGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 悬浮控制条：胶囊玻璃风格 -->
    <Border Name="controls" Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,0"
            CornerRadius="999" Padding="6,4"
            Background="#E01D232C"
            BorderBrush="#26FFFFFF" BorderThickness="1">
      <Border.Styles>
        <Style Selector="PathIcon">
          <Setter Property="Height" Value="15" />
          <Setter Property="Width" Value="15" />
          <Setter Property="Foreground" Value="#F2FFFFFF" />
        </Style>
        <Style Selector="Button">
          <Setter Property="Height" Value="30" />
          <Setter Property="Width" Value="36" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="999" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Background" Value="#24FFFFFF" />
        </Style>
        <Style Selector="Border.BarSeparator">
          <Setter Property="Width" Value="1" />
          <Setter Property="Height" Value="16" />
          <Setter Property="Margin" Value="5,0" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="Background" Value="#2EFFFFFF" />
        </Style>
      </Border.Styles>
      <StackPanel Orientation="Horizontal" Spacing="2">
        <Button IsVisible="{Binding PlayButtonVisible}" Command="{Binding PlayCommand}"
                ToolTip.Tip="开始识别">
          <PathIcon Data="{StaticResource play_regular}" />
        </Button>
        <Button IsVisible="{Binding StopButtonVisible}" Command="{Binding StopCommand}"
                ToolTip.Tip="停止识别">
          <PathIcon Data="{StaticResource stop_regular}" />
        </Button>
        <Border IsVisible="{Binding StopButtonVisible}" CornerRadius="999"
                Background="#33FF5545" Padding="10,0" Margin="2,0" VerticalAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource record_regular}" Width="10" Height="10" Foreground="#FFFF6B5E" />
            <TextBlock Text="{Binding RunningTimeDisplay}" FontSize="12"
                       Foreground="#F2FFFFFF" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
        <Border Classes="BarSeparator" />
        <Button Click="HistoryButton_Click" ToolTip.Tip="识别记录">
          <PathIcon Data="{StaticResource history_regular}" />
        </Button>
        <Button Command="{Binding LockCommand}" ToolTip.Tip="锁定字幕">
          <PathIcon Data="{StaticResource lock_regular}" />
        </Button>
        <Button Click="SettingsButton_Click" ToolTip.Tip="设置">
          <PathIcon Data="{StaticResource settings_regular}" />
        </Button>
        <Border Classes="BarSeparator" />
        <Button Command="{Binding ExitCommand}" ToolTip.Tip="退出 TMSpeech">
          <PathIcon Data="{StaticResource dismiss_regular}" />
        </Button>
      </StackPanel>
    </Border>
    <views:CaptionView Grid.Row="1" Margin="16"
                       FontWeight="Bold"
                       FontColor="{Binding CaptionStyle.FontColor}"
                       FontSize="{Binding CaptionStyle.FontSize}"
                       FontFamily="{Binding CaptionStyle.FontFamily}"
                       TextAlign="{Binding CaptionStyle.TextAlign}"
                       ShadowColor="{Binding CaptionStyle.ShadowColor}"
                       ShadowSize="{Binding CaptionStyle.ShadowSize}"
                       Text="{Binding Text}" />
  </Grid>
</Window>