<Window xmlns="https://github.com/avaloniaui"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
        xmlns:vm="using:TMSpeech.GUI.ViewModels"
        xmlns:controls="using:TMSpeech.GUI.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        Width="420" Height="600"
        x:Class="TMSpeech.GUI.Views.HistoryWindow"
        Icon="/Assets/tmspeech.ico"
        FontFamily="{StaticResource GlobalFontFamily}"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppForegroundBrush}"
        Title="识别记录">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="16,12"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Spacing="2">
        <TextBlock Text="识别记录" FontWeight="SemiBold" FontSize="15" />
        <TextBlock Classes="Small Muted" Text="按住鼠标拖动选择文本，右键复制或全选。" />
      </StackPanel>
    </Border>
    <ScrollViewer Name="scrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <controls:HistoryView ItemsSource="{Binding HistoryTexts}" Margin="10,8" />
    </ScrollViewer>
  </DockPanel>
</Window>